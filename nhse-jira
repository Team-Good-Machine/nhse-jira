import getpass
import re
import sys
import netrc as netrc_mod
from pathlib import Path
from urllib.parse import urlparse

import requests
import yaml


DEFAULT_CONFIG_PATH = Path.home() / ".config" / "nhse-jira" / "config.yml"
DEFAULT_NETRC_PATH = Path.home() / ".netrc"


def load_config(config_path=DEFAULT_CONFIG_PATH):
    config_path = Path(config_path)
    if not config_path.exists():
        print(f"Error: Config file not found: {config_path}", file=sys.stderr)
        raise SystemExit(f"Config file not found: {config_path}")
    with open(config_path) as f:
        return yaml.safe_load(f)


def load_token(server_url, netrc_path=DEFAULT_NETRC_PATH):
    hostname = urlparse(server_url).hostname
    try:
        nrc = netrc_mod.netrc(str(netrc_path))
    except FileNotFoundError:
        print(
            f"Error: No .netrc file found at {netrc_path}\n"
            "Create a Personal Access Token in Jira and add it:\n"
            f"  machine {hostname} login _ password <your-token>",
            file=sys.stderr,
        )
        raise SystemExit(f"No .netrc entry for {hostname}")
    auth = nrc.authenticators(hostname)
    if auth is None:
        print(
            f"Error: No .netrc entry for {hostname}\n"
            "Add this line to your ~/.netrc:\n"
            f"  machine {hostname} login _ password <your-token>",
            file=sys.stderr,
        )
        raise SystemExit(f"No .netrc entry for {hostname}")
    return auth[2]


def normalize_key(key, default_project):
    if key.isdigit():
        return f"{default_project}-{key}"
    return key.upper()


def normalize_jql(jql, default_project):
    if not re.search(r"\bproject\s*=", jql, re.IGNORECASE):
        return f"project = {default_project} AND {jql}"
    return jql


STANDARD_FIELDS = {
    "assignee": ("Assignee", "assignee", "user"),
    "reporter": ("Reporter", "reporter", "user"),
}


def resolve_fields(field_names, custom_fields):
    if not field_names:
        return []
    # Build lookup from standard fields + custom fields (metadata + sections)
    lookup = dict(STANDARD_FIELDS)
    for section in ("metadata", "sections"):
        for label, cfg in custom_fields.get(section, {}).items():
            lookup[label.lower()] = (label, cfg["field"], cfg.get("format", "string"))
    result = []
    for name in field_names:
        key = name.strip().lower()
        if key not in lookup:
            print(f"Error: Unknown field '{name}'", file=sys.stderr)
            raise SystemExit(f"Unknown field: {name}")
        result.append(lookup[key])
    return result


BOLD = "\033[1m"
RESET = "\033[0m"
CYAN = "\033[36m"
GREEN = "\033[32m"
YELLOW = "\033[33m"


def _format_custom_value(raw, fmt):
    if raw is None:
        return "Unassigned" if fmt == "user" else "None"
    if fmt == "option":
        return raw.get("value", str(raw)) if isinstance(raw, dict) else str(raw)
    if fmt == "user":
        return raw.get("displayName", str(raw)) if isinstance(raw, dict) else str(raw)
    return str(raw)


def format_issue(issue, custom_fields=None):
    key = issue["key"]
    fields = issue["fields"]
    summary = fields["summary"]
    status = fields["status"]["name"]
    assignee = fields.get("assignee")
    assignee_name = assignee["displayName"] if assignee else "Unassigned"
    reporter = fields["reporter"]["displayName"]
    description = fields.get("description") or "No description"
    fix_versions = fields.get("fixVersions", [])
    fix_version_str = ", ".join(v["name"] for v in fix_versions) if fix_versions else "None"

    lines = [
        f"{BOLD}{key}: {summary}{RESET}",
        f"{CYAN}Status:{RESET}      {status}",
        f"{CYAN}Assignee:{RESET}    {assignee_name}",
        f"{CYAN}Reporter:{RESET}    {reporter}",
        f"{CYAN}Fix Version:{RESET} {fix_version_str}",
    ]

    if custom_fields:
        for label, cfg in custom_fields.get("metadata", {}).items():
            raw = fields.get(cfg["field"])
            value = _format_custom_value(raw, cfg.get("format", "string"))
            lines.append(f"{CYAN}{label}:{RESET} {value}")

    lines.append("")
    lines.append(description)

    comments = fields.get("comment", {}).get("comments", [])
    if comments:
        last_3 = comments[-3:]
        lines.append("")
        lines.append(f"{BOLD}Comments ({len(last_3)}):{RESET}")
        for comment in last_3:
            author = comment["author"]["displayName"]
            body = comment["body"]
            lines.append(f"  {GREEN}{author}:{RESET} {body}")

    if custom_fields:
        for label, cfg in custom_fields.get("sections", {}).items():
            raw = fields.get(cfg["field"])
            if raw is None:
                continue
            fmt = cfg.get("format", "string")
            if fmt == "checklist":
                value = _format_checklist(raw)
            else:
                value = str(raw)
            lines.append("")
            lines.append(f"{BOLD}{label}:{RESET}")
            lines.append(value)

    return "\n".join(lines)


def _format_checklist(raw):
    if not raw:
        return "No items"
    items = []
    for entry in raw:
        matches = re.findall(
            r"value=(.*?), rank=\d+, status=Status\([^)]*name=(\w[\w ]*)",
            entry,
        )
        for value, status in matches:
            if status == "DONE":
                marker = f"{GREEN}[DONE]{RESET}"
            else:
                marker = f"{YELLOW}[{status}]{RESET}"
            items.append(f"  {marker} {value}")
    return "\n".join(items) if items else "No items"


def format_issue_table(data, extra_fields=None):
    issues = data["issues"]
    if not issues:
        return "No issues found"

    rows = []
    for issue in issues:
        key = issue["key"]
        summary = issue["fields"]["summary"]
        status = issue["fields"]["status"]["name"]
        extras = []
        if extra_fields:
            for _label, field_id, fmt in extra_fields:
                raw = issue["fields"].get(field_id)
                extras.append(_format_custom_value(raw, fmt))
        rows.append((key, summary, status, extras))

    key_width = max(len(r[0]) for r in rows)
    status_width = max(len(r[2]) for r in rows)
    extra_widths = []
    if extra_fields:
        for i, (_label, _fid, _fmt) in enumerate(extra_fields):
            extra_widths.append(max(len(r[3][i]) for r in rows))

    lines = []
    for key, summary, status, extras in rows:
        line = f"{CYAN}{key:<{key_width}}{RESET}  {summary}  {YELLOW}{status:<{status_width}}{RESET}"
        for i, val in enumerate(extras):
            line += f"  {val:<{extra_widths[i]}}"
        lines.append(line)
    return "\n".join(lines)


def format_release(data):
    issues = data["issues"]
    if not issues:
        return "No issues found"
    lines = []
    for issue in issues:
        key = issue["key"]
        summary = issue["fields"]["summary"]
        lines.append(f"{CYAN}[{key}]{RESET} {summary}")
    return "\n".join(lines)


class JiraError(Exception):
    pass


def create_session(token):
    session = requests.Session()
    session.trust_env = False  # prevent requests from applying .netrc Basic auth
    session.headers["Authorization"] = f"Bearer {token}"
    session.headers["Content-Type"] = "application/json"
    return session


def _handle_error(resp):
    try:
        body = resp.json()
        messages = body.get("errorMessages", [])
        msg = "; ".join(messages) if messages else resp.text
    except Exception:
        msg = resp.text
    raise JiraError(f"HTTP {resp.status_code}: {msg}")


def api_get(session, base_url, path, params=None):
    resp = session.get(f"{base_url}/rest/api/2/{path}", params=params)
    if not resp.ok:
        _handle_error(resp)
    return resp.json()


def api_post(session, base_url, path, json=None):
    resp = session.post(f"{base_url}/rest/api/2/{path}", json=json)
    if not resp.ok:
        _handle_error(resp)
    if resp.content:
        return resp.json()


def cmd_view(session, base_url, issue_key, custom_fields=None):
    data = api_get(session, base_url, f"issue/{issue_key}")
    print(format_issue(data, custom_fields=custom_fields))


def build_list_jql(jql="", mine=False, status=None):
    parts = []
    if mine:
        parts.append("assignee = currentUser()")
    if status:
        parts.append(f"status = '{status}'")
    if jql:
        parts.append(jql)
    if not parts:
        return "ORDER BY updated DESC"
    return " AND ".join(parts)


def cmd_list(session, base_url, project, jql="", mine=False, status=None, limit=50, extra_fields=None):
    query = build_list_jql(jql=jql, mine=mine, status=status)
    query = normalize_jql(query, project)
    api_fields = "summary,status"
    if extra_fields:
        api_fields += "," + ",".join(fid for _label, fid, _fmt in extra_fields)
    data = api_get(
        session, base_url, "search",
        params={"jql": query, "maxResults": limit, "fields": api_fields},
    )
    print(format_issue_table(data, extra_fields=extra_fields))


def cmd_transition(session, base_url, issue_key, target_status=None):
    data = api_get(session, base_url, f"issue/{issue_key}/transitions")
    transitions = data["transitions"]
    available = [t["to"]["name"] for t in transitions]

    if target_status is None:
        print(f"Available transitions for {issue_key}:")
        for name in available:
            print(f"  {name}")
        return

    match = None
    for t in transitions:
        if t["to"]["name"].lower() == target_status.lower():
            match = t
            break

    if match is None:
        print(
            f"Error: Cannot transition {issue_key} to '{target_status}'\n"
            f"Available transitions: {', '.join(available)}",
            file=sys.stderr,
        )
        raise SystemExit(1)

    api_post(session, base_url, f"issue/{issue_key}/transitions", json={"transition": {"id": match["id"]}})
    print(f"Transitioned {issue_key} to {target_status}")


def cmd_release(session, base_url, project, version_name, extra_fields=None):
    jql = f'project = {project} AND fixVersion = "{version_name}" ORDER BY key ASC'
    api_fields = "summary,status"
    if extra_fields:
        api_fields += "," + ",".join(fid for _label, fid, _fmt in extra_fields)
    data = api_get(
        session, base_url, "search",
        params={"jql": jql, "maxResults": 200, "fields": api_fields},
    )
    if extra_fields:
        print(format_issue_table(data, extra_fields=extra_fields))
    else:
        print(format_release(data))


def cmd_releases(session, base_url, project, unreleased=False):
    versions = api_get(session, base_url, f"project/{project}/versions")
    if unreleased:
        versions = [v for v in versions if not v.get("released", False)]
    if not versions:
        print("No versions found")
        return
    name_width = max(len(v["name"]) for v in versions)
    lines = []
    for v in versions:
        name = v["name"]
        status = f"{GREEN}Released{RESET}" if v.get("released") else f"{YELLOW}Unreleased{RESET}"
        date = v.get("releaseDate", "")
        lines.append(f"{CYAN}{name:<{name_width}}{RESET}  {status}  {date}")
    print("\n".join(lines))


DEFAULT_SERVER = "https://nhsd-jira.digital.nhs.uk"
DEFAULT_PROJECT = "MAV"


def cmd_init(config_dir=None, netrc_path=None):
    if config_dir is None:
        config_dir = Path.home() / ".config" / "nhse-jira"
    config_dir = Path(config_dir)
    if netrc_path is None:
        netrc_path = Path.home() / ".netrc"
    netrc_path = Path(netrc_path)

    config_file = config_dir / "config.yml"

    # If config already exists, ask before overwriting
    if config_file.exists():
        answer = input(f"Config already exists at {config_file}. Overwrite? [y/N] ")
        if answer.lower() != "y":
            return

    server = input(f"Jira server URL [{DEFAULT_SERVER}]: ").strip() or DEFAULT_SERVER
    hostname = urlparse(server).hostname

    pat_url = f"{server}/secure/ViewProfile.jspa?selectedTab=com.atlassian.pats.pats-plugin:jira-user-personal-access-tokens"
    print(f"\nCreate a Personal Access Token at:\n  {pat_url}\n")
    token = getpass.getpass("Paste your token: ")

    project = input(f"Default project [{DEFAULT_PROJECT}]: ").strip() or DEFAULT_PROJECT

    # Write config
    config_dir.mkdir(parents=True, exist_ok=True)
    config_content = f"server: {server}\nproject: {project}\n"
    if project.upper() == "MAV":
        config_content += (
            "custom_fields:\n"
            "  metadata:\n"
            "    Clinical Severity:\n"
            "      field: customfield_37401\n"
            "      format: option\n"
            "    Clinical Safety:\n"
            "      field: customfield_10595\n"
            "      format: option\n"
            "    Checklist Progress:\n"
            "      field: customfield_22907\n"
            "      format: string\n"
            "  sections:\n"
            "    Clinical Summary:\n"
            "      field: customfield_37408\n"
            "      format: string\n"
            "    Test Summary:\n"
            "      field: customfield_37407\n"
            "      format: string\n"
            "    Smart Checklist:\n"
            "      field: customfield_22905\n"
            "      format: checklist\n"
        )
    config_file.write_text(config_content)

    # Write netrc
    entry = f"machine {hostname} login _ password {token}\n"
    if netrc_path.exists():
        existing = netrc_path.read_text()
        if hostname not in existing:
            netrc_path.write_text(existing.rstrip("\n") + "\n" + entry)
    else:
        netrc_path.write_text(entry)
        netrc_path.chmod(0o600)

    print(f"\nConfig written to {config_file}")
    print(f"Token saved to {netrc_path}")


import argparse


def build_parser():
    parser = argparse.ArgumentParser(prog="nhse-jira", description="CLI for NHSE Jira")
    subparsers = parser.add_subparsers(dest="command", required=True)

    FMT = argparse.RawDescriptionHelpFormatter

    subparsers.add_parser("init", help="Set up config and authentication")

    view_parser = subparsers.add_parser("view", help="View issue details",
        formatter_class=FMT,
        epilog="examples:\n"
               "  nhse-jira view MAV-5902   view by full key\n"
               "  nhse-jira view 5902       uses default project")
    view_parser.add_argument("issue", help="Issue key or number")

    list_parser = subparsers.add_parser("list", help="Search issues with JQL",
        formatter_class=FMT,
        epilog="examples:\n"
               "  nhse-jira list --mine                       my open issues\n"
               "  nhse-jira list --mine --status \"In Progress\" my in-progress issues\n"
               "  nhse-jira list \"type = Bug\"                  JQL search\n"
               "  nhse-jira list --limit 10 \"priority = High\" limited results\n"
               "  nhse-jira list --mine --fields \"clinical safety,checklist progress\" with extra columns")
    list_parser.add_argument("jql", nargs="?", default="", help="JQL query")
    list_parser.add_argument("--mine", action="store_true", help="Only my issues")
    list_parser.add_argument("--status", help="Filter by status")
    list_parser.add_argument("--limit", type=int, default=50, help="Max results (default: 50)")
    list_parser.add_argument("--fields", default=None, help="Extra fields to show (comma-separated custom field labels)")

    trans_parser = subparsers.add_parser("transition", help="Transition an issue",
        formatter_class=FMT,
        epilog="examples:\n"
               "  nhse-jira transition 5902              list available transitions\n"
               "  nhse-jira transition 5902 \"In Progress\" move to In Progress\n"
               "  nhse-jira transition MAV-5902 Done     mark as done")
    trans_parser.add_argument("issue", help="Issue key or number")
    trans_parser.add_argument("status", nargs="?", default=None, help="Target status (omit to list available)")

    release_parser = subparsers.add_parser("release", help="List issues in a release",
        formatter_class=FMT,
        epilog="examples:\n"
               "  nhse-jira release v7.8.0\n"
               "  nhse-jira release v7.9.0 --fields \"clinical safety,checklist progress\" with assurance columns")
    release_parser.add_argument("version", help="Version name")
    release_parser.add_argument("--fields", default=None, help="Extra fields to show (comma-separated custom field labels)")

    releases_parser = subparsers.add_parser("releases", help="List project versions",
        formatter_class=FMT,
        epilog="examples:\n"
               "  nhse-jira releases              all versions\n"
               "  nhse-jira releases --unreleased  only unreleased")
    releases_parser.add_argument("--unreleased", action="store_true", help="Only unreleased versions")

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()

    if args.command == "init":
        cmd_init()
        return

    config = load_config()
    token = load_token(config["server"])
    session = create_session(token)
    base_url = config["server"]
    project = config["project"]

    try:
        if args.command == "view":
            issue_key = normalize_key(args.issue, project)
            cmd_view(session, base_url, issue_key, custom_fields=config.get("custom_fields"))
        elif args.command == "list":
            extra = resolve_fields(args.fields.split(",") if args.fields else None, config.get("custom_fields", {}))
            cmd_list(session, base_url, project, jql=args.jql, mine=args.mine, status=args.status, limit=args.limit, extra_fields=extra or None)
        elif args.command == "transition":
            issue_key = normalize_key(args.issue, project)
            cmd_transition(session, base_url, issue_key, args.status)
        elif args.command == "release":
            extra = resolve_fields(args.fields.split(",") if args.fields else None, config.get("custom_fields", {}))
            cmd_release(session, base_url, project, args.version, extra_fields=extra or None)
        elif args.command == "releases":
            cmd_releases(session, base_url, project, unreleased=args.unreleased)
    except JiraError as e:
        print(f"Error: {e}", file=sys.stderr)
        raise SystemExit(1)


if __name__ == "__main__":
    main()
